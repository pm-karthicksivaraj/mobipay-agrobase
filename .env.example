# ============================================
# Agrobase V3 — Environment Variables Template
# Copy to .env and fill in production values
# ============================================

# --- Database ---
# SQLite (development):
DATABASE_URL=file:./db/dev.db
# PostgreSQL (production via docker-compose):
# DATABASE_URL=postgresql://agrobase:agrobase_dev_pass@localhost:5432/agrobase_v3?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- NextAuth ---
NEXTAUTH_SECRET=change-me-in-production-use-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# --- PostgreSQL (used by docker-compose) ---
POSTGRES_USER=agrobase
POSTGRES_PASSWORD=agrobase_dev_pass
POSTGRES_DB=agrobase_v3
POSTGRES_PORT=5432

# --- Redis (used by docker-compose) ---
REDIS_PORT=6379

# --- App ---
APP_PORT=3000
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# --- Payment Providers (placeholders) ---
MPAY_API_KEY=
MPAY_BASE_URL=
AINTEL_API_KEY=
AINTEL_BASE_URL=
MTN_MOMO_API_KEY=
AIRTEL_MONEY_API_KEY=

# --- Satellite Data (free APIs) ---
SENTINEL_HUB_API_KEY=
USGS_API_KEY=