# ============================================
# Agrobase V3 — Environment Variables Template
# Copy to .env and fill in production values
# ============================================

# --- Database ---
# Option A: Neon.tech (serverless PostgreSQL — recommended for Vercel)
#   1. Create a project at https://neon.tech
#   2. Copy the "Pooled connection" string from the dashboard
#   3. Replace the credentials below
#   Format: postgresql://USER:PASSWORD@ep-XXX-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&schema=public
DATABASE_URL=postgresql://user:password@ep-cool-name-123456-pooler.us-east-2.aws.neon.tech/agrobase?sslmode=require&schema=public

# Direct connection (for Prisma migrations — NOT pooled)
# Neon: use the "Direct connection" string (without -pooler-)
DIRECT_URL=postgresql://user:password@ep-cool-name-123456.us-east-2.aws.neon.tech/agrobase?sslmode=require&schema=public

# Option B: SQLite (local dev only — NOT for production)
# DATABASE_URL=file:./db/dev.db

# Option C: Docker PostgreSQL (self-hosted)
# DATABASE_URL=postgresql://agrobase:agrobase_dev_pass@localhost:5432/agrobase_v3?schema=public

# --- NextAuth ---
NEXTAUTH_SECRET=change-me-in-production-use-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# --- Vercel Cron ---
# CRON_SECRET is auto-set by Vercel when crons are enabled in vercel.json
# Set IMPACT_CRON_SECRET if you want to call cron from external schedulers
IMPACT_CRON_SECRET=

# --- Redis (optional — rate limiting + session cache) ---
# On Vercel, use Upstash Redis (serverless): https://upstash.com
REDIS_URL=redis://localhost:6379

# --- Payment Providers ---
MPAY_API_KEY=
MPAY_BASE_URL=
AINTEL_API_KEY=
AINTEL_BASE_URL=
MTN_MOMO_API_KEY=
AIRTEL_MONEY_API_KEY=

# --- Payment Webhook Secrets (HMAC verification) ---
AINTEL_WEBHOOK_SECRET=
MPAY_WEBHOOK_SECRET=
MTN_MOMO_WEBHOOK_SECRET=
MPESA_WEBHOOK_SECRET=
BANK_WEBHOOK_SECRET=

# --- Satellite Data (free APIs) ---
SENTINEL_HUB_API_KEY=
USGS_API_KEY=

# --- S3 / Object Storage (for export files + attachments) ---
# On Vercel, use Cloudflare R2, AWS S3, or Uploadthing
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=agrobase-exports
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_USE_SSL=false
EXPORT_LINK_TTL_DAYS=7
EXPORT_MAX_FILE_SIZE_MB=50
EXPORT_MAX_ROW_LIMIT=50000

# --- Docker Compose (only needed for self-hosted Docker) ---
POSTGRES_USER=agrobase
POSTGRES_PASSWORD=agrobase_dev_pass
POSTGRES_DB=agrobase_v3
POSTGRES_PORT=5432
REDIS_PORT=6379
APP_PORT=3000
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
