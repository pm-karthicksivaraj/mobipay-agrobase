# --- Database (PostgreSQL via docker-compose) ---
DATABASE_URL=postgresql://agrobase:agrobase_dev_pass@localhost:5432/agrobase_v3?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- NextAuth ---
NEXTAUTH_SECRET=agrobase-v3-dev-secret-change-in-production
NEXTAUTH_URL=http://localhost:3000

# --- Docker Compose ---
POSTGRES_USER=agrobase
POSTGRES_PASSWORD=agrobase_dev_pass
POSTGRES_DB=agrobase_v3
POSTGRES_PORT=5432
REDIS_PORT=6379
APP_PORT=3000
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443