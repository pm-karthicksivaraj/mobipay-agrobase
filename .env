# Agrobase V3 — Environment Configuration
# Copy to .env.local for local overrides

# Database (PostgreSQL for production, SQLite for local dev)
DATABASE_URL=postgresql://agrobase:agrobase_dev_pass@localhost:5432/agrobase_v3?schema=public

# Auth
NEXTAUTH_SECRET=agrobase-v3-dev-secret-change-in-production
NEXTAUTH_URL=http://localhost:3000

# Redis (optional — falls back to in-memory if not set)
REDIS_URL=redis://localhost:6379/0