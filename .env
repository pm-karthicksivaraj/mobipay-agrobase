# ============================================
# Agrobase V3 — Local Development (macOS + PostgreSQL)
# ============================================

# --- Database ---
# PostgreSQL on your MacBook (create this DB first: createdb agrobase_v3)
DATABASE_URL=postgresql://localhost:5432/agrobase_v3?schema=public

# --- NextAuth ---
NEXTAUTH_SECRET=agrobase-local-dev-secret-change-in-prod
NEXTAUTH_URL=http://localhost:3000

# --- Redis (optional for local dev — app works without it) ---
# REDIS_URL=redis://localhost:6379

# --- App ---
APP_PORT=3000

# --- Payment Providers (leave empty for local dev) ---
MPAY_API_KEY=
MPAY_BASE_URL=
AINTEL_API_KEY=
AINTEL_BASE_URL=
MTN_MOMO_API_KEY=
AIRTEL_MONEY_API_KEY=

# --- Satellite Data (free APIs — get keys from https://dataspace.copernicus.eu/) ---
SENTINEL_HUB_API_KEY=
USGS_API_KEY=

# --- S3 / MinIO Object Storage (optional for local dev) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=agrobase-exports
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_USE_SSL=false
EXPORT_LINK_TTL_DAYS=7
EXPORT_MAX_FILE_SIZE_MB=50
EXPORT_MAX_ROW_LIMIT=50000
