// --- ESCROW & SETTLEMENT ---

model Escrow {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation("TenantEscrow", fields: [tenantId], references: [id])

  // Source transaction that funded this escrow
  sourceType      String                    // SALE, PURCHASE, CONSIGNMENT, MARKETPLACE_ORDER
  sourceId        String                    // ID of the Sale/Purchase/Consignment record
  reference       String   @unique          // Human-readable: "ESC-2024-001"

  // Parties
  payerId         String?                   // who pays into escrow (buyer / cooperative)
  payeeId         String?                   // who receives on release (farmer / supplier)
  payerName       String?
  payeeName       String?

  // Amount
  amount          Float
  currency        String   @default("UGX")
  feeAmount       Float    @default(0)      // platform fee withheld on release
  feeRate         Float    @default(0)      // percentage, e.g. 2.5

  // Lifecycle
  status          String   @default("PENDING")
  // PENDING → HELD → RELEASED / PARTIALLY_RELEASED / REFUNDED / DISPUTED / EXPIRED

  heldAt          DateTime?
  heldBy          String?
  releasedAt      DateTime?
  releasedBy      String?
  releasedAmount  Float    @default(0)
  refundedAt      DateTime?
  refundedBy      String?
  refundedAmount  Float    @default(0)
  disputedAt      DateTime?
  disputedBy      String?
  disputeReason   String?

  // Conditions for release
  releaseConditions String?                  // JSON: { "type": "delivery_confirmation", "deliveryId": "xxx" }
  autoReleaseAt   DateTime?                  // auto-release if not disputed by this time

  // Linked payment
  paymentTxnId    String?   @unique
  paymentTxn      PaymentTransaction? @relation("EscrowPayment", fields: [paymentTxnId], references: [id])

  metadata        String?                    // JSON for additional data
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  settlements     Settlement[]

  @@index([tenantId])
  @@index([status])
  @@index([sourceType, sourceId])
  @@index([payeeId])
  @@index([payerId])
}

model Settlement {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation("TenantSettlement", fields: [tenantId], references: [id])

  escrowId        String?
  escrow          Escrow?  @relation(fields: [escrowId], references: [id])

  // What is being settled
  sourceType      String                    // ESCROW, COOPERATIVE_PAYMENT, COMMISSION, MARKETPLACE_PAYOUT
  sourceId        String?                   // ID of the source record
  reference       String   @unique          // "SET-2024-001"

  // Beneficiary
  beneficiaryId   String?                   // User or farmer receiving funds
  beneficiaryName String?
  beneficiaryPhone String?

  // Amounts
  grossAmount     Float
  deductions      Float    @default(0)      // total deductions (fees, taxes, penalties)
  netAmount       Float
  currency        String   @default("UGX")

  // Lifecycle
  status          String   @default("PENDING")
  // PENDING → APPROVED → PROCESSING → COMPLETED / FAILED / REVERSED

  // Payment execution
  paymentMethod   String?                   // MOBILE_MONEY, BANK, CASH, WALLET
  paymentTxnId    String?   @unique
  paymentTxn      PaymentTransaction? @relation("SettlementPayment", fields: [paymentTxnId], references: [id])
  initiatedAt     DateTime?
  completedAt     DateTime?
  failedAt        DateTime?
  failureReason   String?

  // Accounting
  journalEntryId  String?   @unique
  journalEntry    JournalEntry? @relation("SettlementJournal", fields: [journalEntryId], references: [id])

  // Batch
  batchId         String?                   // for grouping settlements in a batch run
  batchReference  String?

  // Audit
  approvedBy      String?
  approvedAt      DateTime?
  initiatedBy     String?
  metadata        String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([sourceType, sourceId])
  @@index([beneficiaryId])
  @@index([batchId])
}

// ---------------------------------------------------------------------------
// Data Export Jobs (async export to S3/MinIO)
// ---------------------------------------------------------------------------

model ExportJob {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation("TenantExportJob", fields: [tenantId], references: [id])

  // What to export
  exportType    String                       // farmers, purchases, inventory, contracts, shipments, partners, vsla_savings, vsla_loans, payments, accounting, traceability
  format        String   @default("CSV")     // CSV, JSON, XLSX
  status        String   @default("PENDING") // PENDING, GENERATING, COMPLETED, FAILED, EXPIRED, CANCELLED

  // Requestor
  requestedBy   String?                      // userId who triggered the export

  // Filters & column selection
  filters       String?                      // JSON: { dateFrom, dateTo, status, ... }
  columns       String?                      // JSON: string[] of selected columns

  // Result
  fileKey       String?                      // S3 object key: exports/{tenantId}/{type}_{timestamp}.{ext}
  fileName      String?                      // human-friendly download name
  fileSize      Int?                         // bytes
  rowCount      Int?                         // number of rows in the export
  fileChecksum  String?                      // MD5 or SHA256 for integrity

  // Presigned URL (generated on demand, cached)
  downloadUrl   String?
  downloadUrlExpiry DateTime?

  // Lifecycle timestamps
  startedAt     DateTime?
  completedAt   DateTime?
  failedAt      DateTime?
  failureReason String?
  expiresAt     DateTime?                    // auto-expire link after N days

  // Retry
  attemptCount  Int      @default(0)
  maxAttempts   Int      @default(3)

  metadata      String?                      // JSON: additional context

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([exportType])
  @@index([requestedBy])
  @@index([expiresAt])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// TRANSPORT & LOGISTICS — "Mini Uber for Transporters"
// Eric's requirement: transporter onboarding, ride-request flow, real-time
// tracking, exporter visibility, charges/commission.
// ---------------------------------------------------------------------------

// Vehicle types supported: MOTORBIKE, MINI_TRUCK, LORRY, TRAILER, PICKUP, VAN
// Commodity scope: agricultural AND non-agricultural

model Transporter {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation("TenantTransporters", fields: [tenantId], references: [id])

  // Identity
  transporterCode String   @unique              // "TRP-000001"
  name            String                        // person or company name
  type            String                        // INDIVIDUAL, COMPANY
  contactName     String?                       // for companies: primary contact
  phone           String
  email           String?
  nationalIdNo    String?                       // ID verification
  photoUrl        String?                       // profile photo

  // Business details
  operatingRegions String?                      // JSON: list of regions/districts
  commodityTypes   String?                      // JSON: ["MAIZE", "COFFEE", "GENERAL"] — what they transport
  bankName        String?
  bankAccountNo   String?
  bankBranch      String?

  // Status & verification
  status          String   @default("PENDING")  // PENDING, VERIFIED, ACTIVE, SUSPENDED
  verifiedBy      String?
  verifiedAt      DateTime?
  isAvailable     Boolean  @default(true)       // accepting new requests
  rating          Float?                        // 1-5 average rating
  totalTrips      Int      @default(0)
  totalEarnings   Float    @default(0)          // cumulative earnings
  commissionRate  Float?                        // platform commission % for this transporter

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vehicles        TransportVehicle[]
  trips           TransportTrip[]
  charges         TransportCharge[]

  @@index([tenantId])
  @@index([status])
  @@index([phone])
  @@index([type])
}

model TransportVehicle {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation("TenantTransportVehicles", fields: [tenantId], references: [id])
  transporterId   String
  transporter     Transporter @relation(fields: [transporterId], references: [id], onDelete: Cascade)

  // Vehicle details
  plateNumber     String                        // registration plate
  vehicleType     String                        // MOTORBIKE, MINI_TRUCK, PICKUP, LORRY, TRAILER, VAN
  make            String?                       // Toyota, Honda, etc.
  model           String?                       // Hilux, Canter, etc.
  year            Int?
  color           String?

  // Capacity
  capacityKg      Float?                        // max weight in kg
  capacityVolume  Float?                        // cubic meters
  palletSpaces    Int?

  // Driver (may differ from transporter owner)
  driverName      String
  driverPhone     String
  driverLicenseNo String?

  // Documents
  insuranceExpiry   DateTime?
  inspectionExpiry  DateTime?
  roadLicenseExpiry DateTime?

  // Status
  isActive        Boolean  @default(true)
  isAvailable     Boolean  @default(true)       // currently available for trips
  currentTripId   String?                       // if on a trip, link to active trip

  // Location (last known)
  lastLatitude    Float?
  lastLongitude   Float?
  lastLocationAt  DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trips           TransportTrip[]

  @@unique([tenantId, plateNumber])
  @@index([tenantId])
  @@index([transporterId])
  @@index([vehicleType])
  @@index([isAvailable])
}

model TransportRequest {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation("TenantTransportRequests", fields: [tenantId], references: [id])

  // Request reference
  requestCode     String   @unique              // "TREQ-000001"

  // Who is requesting transport (shipper)
  requestedBy     String                        // userId who created the request
  requesterName   String
  requesterPhone  String
  requesterType   String                        // EXPORTER, COOPERATIVE, AGENT, FARMER, COMPANY

  // Pickup details
  pickupAddress   String
  pickupLatitude  Float?
  pickupLongitude Float?
  pickupDistrict  String?

  // Drop-off details
  dropoffAddress  String
  dropoffLatitude Float?
  dropoffLongitude Float?
  dropoffDistrict String?

  // Cargo details
  commodityType   String                        // MAIZE, COFFEE, GENERAL_GOODS, etc.
  commodityCategory String                      // AGRICULTURAL, NON_AGRICULTURAL
  weightKg        Float?
  volumeM3        Float?
  quantityBags    Int?
  requiresRefrigeration Boolean @default(false)

  // Vehicle preference
  preferredVehicleType String?                  // MOTORBIKE, MINI_TRUCK, LORRY, TRAILER
  vehicleTypeRequired  String?                  // strict requirement or preference

  // Schedule
  requestedPickupTime DateTime?                 // when they want pickup
  isUrgent        Boolean  @default(false)

  // Budget & pricing
  proposedBudget  Float?                        // what shipper is willing to pay
  estimatedCost   Float?                        // system-estimated cost
  finalCost       Float?                        // agreed/negotiated cost

  // Related entities (integration points)
  relatedId       String?                       // e.g. consignmentId, orderId, contractId
  relatedType     String?                       // CONSIGNMENT, PURCHASE, CONTRACT, MARKET_MATCH
  eudrBatchId     String?                       // link to EUDR compliance batch

  // Matching
  matchedTransporterId String?
  matchedVehicleId     String?

  // Lifecycle: OPEN → MATCHING → MATCHED → ACCEPTED → PICKED_UP → IN_TRANSIT → DELIVERED → CANCELLED
  status          String   @default("OPEN")

  // Cancellation
  cancelledBy     String?
  cancelledAt     DateTime?
  cancellationReason String?

  // Completion
  deliveredAt     DateTime?
  deliveryNote    String?
  podPhotoUrl     String?                       // proof of delivery photo
  podSignedBy     String?

  // Timestamps
  acceptedAt      DateTime?
  pickupAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trip            TransportTrip?

  @@index([tenantId])
  @@index([status])
  @@index([requestedBy])
  @@index([requesterType])
  @@index([commodityCategory])
  @@index([matchedTransporterId])
  @@index([createdAt])
}

model TransportTrip {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation("TenantTransportTrips", fields: [tenantId], references: [id])

  // Trip reference
  tripCode        String   @unique              // "TRP-TRIP-000001"

  // Linked request
  requestId       String   @unique
  request         TransportRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  // Transporter & Vehicle
  transporterId   String
  transporter     Transporter @relation(fields: [transporterId], references: [id])
  vehicleId       String
  vehicle         TransportVehicle @relation(fields: [vehicleId], references: [id])

  // Driver (at time of trip — snapshot)
  driverName      String
  driverPhone     String

  // Route details
  originAddress   String
  originLatitude  Float?
  originLongitude Float?
  destinationAddress String
  destinationLatitude  Float?
  destinationLongitude Float?
  estimatedDistanceKm  Float?                   // system-calculated
  actualDistanceKm     Float?                   // calculated from GPS events
  estimatedDurationMin Float?                  // system-calculated
  actualDurationMin    Float?                   // pickup to delivery

  // Cargo snapshot
  commodityType   String
  commodityCategory String
  weightKg        Float?

  // Financial
  agreedCost      Float                         // negotiated/final cost
  platformCommission Float                      // platform's cut
  transporterEarnings Float                     // what transporter gets
  paymentStatus   String   @default("UNPAID")  // UNPAID, PAID, PROCESSING
  paidAt          DateTime?

  // Lifecycle: ASSIGNED → PICKED_UP → IN_TRANSIT → ARRIVED → DELIVERED → CANCELLED
  status          String   @default("ASSIGNED")

  // Timestamps
  assignedAt      DateTime @default(now())
  pickedUpAt      DateTime?
  departedAt      DateTime?                      // left pickup location
  arrivedAt       DateTime?                      // arrived at destination
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?

  // EUDR chain-of-custody link
  eudrComplianceId String?

  // Tracking & events
  trackingEvents  TripTrackingEvent[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  charges         TransportCharge[]

  @@index([tenantId])
  @@index([status])
  @@index([transporterId])
  @@index([vehicleId])
  @@index([driverPhone])
  @@index([paymentStatus])
  @@index([assignedAt])
  @@index([createdAt])
}

model TripTrackingEvent {
  id              String   @id @default(cuid())
  tripId          String
  trip            TransportTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  // GPS data
  latitude        Float
  longitude       Float
  speedKmh        Float?                        // speed at this point
  heading         Float?                        // direction in degrees
  accuracyMeters  Float?                        // GPS accuracy

  // Context
  eventType       String                        // LOCATION_UPDATE, PICKUP, DEPARTURE, WAYPOINT, ARRIVAL, DELIVERY, STOP, IDLE
  address         String?                       // reverse-geocoded address
  district        String?
  batteryLevel    Int?                          // device battery %
  odometerKm      Float?                        // cumulative odometer reading

  // Timestamp
  recordedAt      DateTime @default(now())

  @@index([tripId])
  @@index([recordedAt])
  @@index([eventType])
  @@index([latitude, longitude])
}

model TransportCharge {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation("TenantTransportCharges", fields: [tenantId], references: [id])

  // What trip/transporter this charge relates to
  tripId          String?
  trip            TransportTrip? @relation(fields: [tripId], references: [id])
  transporterId   String?
  transporter     Transporter? @relation(fields: [transporterId], references: [id])

  // Charge details
  chargeType      String                        // TRIP_FEE, COMMISSION, INSURANCE, PARKING, TOLL, PENALTY, BONUS, ADJUSTMENT
  description     String?
  amount          Float
  currency        String   @default("UGX")

  // Direction
  direction       String                        // DEBIT (charge to transporter), CREDIT (pay to transporter)

  // Payment
  paymentStatus   String   @default("PENDING")  // PENDING, PAID, FAILED, WAIVED
  paymentMethod   String?                       // MOBILE_MONEY, BANK, WALLET
  paymentRef      String?
  paidAt          DateTime?

  // Accounting integration
  journalEntryId  String?   @unique

  // Period
  periodStart     DateTime?
  periodEnd       DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([tripId])
  @@index([transporterId])
  @@index([chargeType])
  @@index([paymentStatus])
  @@index([createdAt])
}

// ============================================
// PLOT-LEVEL TRACEABILITY
// ============================================

model Plot {
  id                   String   @id @default(cuid())
  tenantId             String
  tenant               Tenant   @relation("TenantPlots", fields: [tenantId], references: [id])
  plotCode             String   @unique
  name                 String
  farmerId             String?
  farmer               FarmerProfile? @relation("FarmerPlots", fields: [farmerId], references: [id])
  farmLandId           String?
  farmName             String?
  description          String?
  plotType             String   @default("PRODUCTION")  // PRODUCTION | NURSERY | PROCESSING | DEMO
  boundaryGeoJson      String?                          // GeoJSON Polygon stored as text
  areaHectares         Float?
  centroidLat          Float?
  centroidLng          Float?
  soilType             String?
  elevationM           Float?
  slopePercent         Float?
  irrigationType       String?
  landOwnership        String?
  tags                 String?                         // JSON array stored as text
  verificationStatus   String   @default("UNVERIFIED") // UNVERIFIED | GPS_VERIFIED | SATELLITE_VERIFIED | FIELD_AUDITED | VERIFIED
  verificationMethod   String?
  verificationScore    Float?
  verifiedBy           String?
  verifiedAt           DateTime?
  eudrRiskLevel        String   @default("UNKNOWN")    // LOW | MEDIUM | HIGH | UNKNOWN
  deforestationFree    Boolean  @default(false)
  lastSatelliteCheck   DateTime?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  seasons      PlotSeason[]
  verifications PlotVerification[]
  documents    PlotDocument[]
  batches      ProductBatch[]

  @@index([tenantId])
  @@index([farmerId])
  @@index([verificationStatus])
  @@index([eudrRiskLevel])
  @@index([plotCode])
}

model PlotSeason {
  id                   String   @id @default(cuid())
  tenantId             String
  tenant               Tenant   @relation("TenantPlotSeasons", fields: [tenantId], references: [id])
  plotId               String
  plot                 Plot     @relation(fields: [plotId], references: [id], onDelete: Cascade)
  season               String
  cropType             String
  variety              String?
  plantingDate         DateTime?
  expectedHarvestDate  DateTime?
  actualHarvestDate    DateTime?
  areaPlantedHectares  Float?
  yieldKg              Float?
  qualityGrade         String?
  status               String   @default("PLANNED")     // PLANNED | PLANTED | GROWING | HARVESTED | COMPLETED | ABANDONED
  eudrCompliant        Boolean?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([plotId, season, cropType])
  @@index([tenantId])
  @@index([plotId])
}

model PlotVerification {
  id                   String   @id @default(cuid())
  tenantId             String
  tenant               Tenant   @relation("TenantPlotVerifications", fields: [tenantId], references: [id])
  plotId               String
  plot                 Plot     @relation(fields: [plotId], references: [id], onDelete: Cascade)
  verificationType     String   // GPS | SATELLITE | DRONE | FIELD_AUDIT | COMBINED
  result               String   // PASSED | FAILED | NEEDS_REVIEW | PENDING
  verifiedBy           String?
  verifiedAt           DateTime?
  boundaryMatchPercent Float?
  accuracyMeters       Float?
  deforestCheckResult  String?
  evidence             String?  // JSON
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([tenantId])
  @@index([plotId])
  @@index([verificationType])
}

model PlotDocument {
  id                   String   @id @default(cuid())
  tenantId             String
  tenant               Tenant   @relation("TenantPlotDocuments", fields: [tenantId], references: [id])
  plotId               String
  plot                 Plot     @relation(fields: [plotId], references: [id], onDelete: Cascade)
  docType              String   // LAND_TITLE | LEASE_AGREEMENT | SURVEY_REPORT | EUDR_CERTIFICATE | SATELLITE_IMAGE | COMPLIANCE_REPORT
  title                String?
  fileUrl              String?
  issuedBy             String?
  issuedAt             DateTime?
  expiresAt            DateTime?
  isVerified           Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([tenantId])
  @@index([plotId])
  @@index([docType])
}

// ============================================
// CARBON CREDITS SYSTEM
// ============================================

model CarbonProject {
  id                       String   @id @default(uuid())
  tenantId                 String
  tenant                   Tenant   @relation("TenantCarbonProjects", fields: [tenantId], references: [id])
  createdById              String?
  createdBy                User?    @relation("UserCarbonProjects", fields: [createdById], references: [id])
  name                     String
  description              String?
  standard                 String   // VERRA_VCS | GOLD_STANDARD | PLANET | AMERICAN_CARBON_REGISTRY
  methodologyCode          String
  methodologyVersion       String?
  projectType              String   // AFFORESTATION | REFORESTATION | AGRICULTURE | SOIL_CARBON | BIOCHAR | AGROFORESTRY
  region                   String?
  country                  String?
  totalAreaHectares        Float?
  estimatedAnnualRemovals  Float?
  projectStartDate         DateTime?
  projectEndDate           DateTime?
  creditingPeriodYears     Int?
  creditingPeriodStart     DateTime?
  creditingPeriodEnd       DateTime?
  proponentName            String?
  proponentContact         String?
  vvbName                  String?
  vvbContact               String?
  baselineScenario         String?  // JSON
  monitoringPlan           String?  // JSON
  status                   String   @default("DRAFT") // DRAFT | SUBMITTED | VALIDATED | REGISTERED | ACTIVE | SUSPENDED | CLOSED
  verraProjectId           String?
  goldStandardId           String?
  pddDocumentUrl           String?
  metadata                 String?  // JSON
  totalCreditsIssued       Float    @default(0)
  totalCreditsRetired      Float    @default(0)
  totalCreditsTransferred  Float    @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  credits        CarbonCredit[]
  verifications  CarbonVerification[]
  methodologies   CarbonProjectMethodology[]

  @@index([tenantId])
  @@index([status])
  @@index([standard])
}

model CarbonCredit {
  id                  String    @id @default(uuid())
  tenantId            String
  tenant              Tenant    @relation("TenantCarbonCredits", fields: [tenantId], references: [id])
  projectId           String
  project             CarbonProject   @relation(fields: [projectId], references: [id])
  verificationId      String?
  verification        CarbonVerification? @relation(fields: [verificationId], references: [id])
  vintageYear         Int
  quantityTonnesCO2   Decimal   @default(0) @db.Decimal(18, 6)
  status              String    @default("PENDING") // PENDING | ISSUED | VERIFIED | RETIRED | TRANSFERRED | EXPIRED | CANCELLED
  serialNumber        String?
  batchNumber         String?
  issuanceDate        DateTime  @default(now())
  expiryDate          DateTime?
  originType          String?   // REMOVAL | AVOIDANCE | REDUCTION
  unitPriceUsd        Decimal?  @db.Decimal(12, 2)
  totalValueUsd       Decimal?  @db.Decimal(14, 2)
  notes               String?
  retirementReason    String?   // VOLUNTARY | COMPLIANCE | CBAM_OFFSET
  retirementDate      DateTime?
  retiredById         String?
  retiredOnBehalfOf   String?
  transferDate        DateTime?
  transferTo          String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([tenantId])
  @@index([projectId])
  @@index([status])
  @@index([vintageYear])
  @@index([expiryDate])
}

model CarbonVerification {
  id                  String    @id @default(uuid())
  tenantId            String
  tenant              Tenant    @relation("TenantCarbonVerifications", fields: [tenantId], references: [id])
  projectId           String
  project             CarbonProject   @relation(fields: [projectId], references: [id])
  type                String    // VALIDATION | VERIFICATION | POST_VALIDATION
  status              String    @default("SCHEDULED") // SCHEDULED | IN_PROGRESS | COMPLETED | REJECTED | CORRECTIVE_ACTION
  vvbName             String
  vvbAccreditation    String?
  startDate           DateTime?
  endDate             DateTime?
  performedById       String?
  scope               String?   // JSON
  findings            String?   // JSON
  nonConformities     String?   // JSON
  correctiveActions   String?   // JSON
  conclusion          String?   // POSITIVE | POSITIVE_WITH_CONDITIONS | NEGATIVE
  recommendation      String?   // ISSUE | HOLD | REJECT
  reportUrl           String?
  statementUrl        String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  credits  CarbonCredit[]

  @@index([tenantId])
  @@index([projectId])
  @@index([status])
}

model CarbonProjectMethodology {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation("TenantCarbonProjectMethodologies", fields: [tenantId], references: [id])
  projectId        String
  project          CarbonProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  methodologyCode  String
  parameterName    String
  parameterValue   Float
  parameterUnit    String?
  source           String?
  confidence       String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([projectId, methodologyCode, parameterName])
  @@index([tenantId])
  @@index([projectId])
}

// ============================================
// MFI (MICROFINANCE) MODULE
// ============================================

model MfiPartner {
