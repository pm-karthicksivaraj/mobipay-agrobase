generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AGROBASE V3 — FULL MULTI-TENANT SCHEMA
// MobiPay AgroSys Limited
// ============================================

// --- TENANT & ORG HIERARCHY ---

model Tenant {
  id          String   @id @default(cuid())
  name        String
  type        String   // SUPER_ADMIN, COUNTRY, NGO, COOPERATIVE, AGRIBUSINESS, EXPORTER, MFI, BANK, INPUT_SUPPLIER, PROCESSING
  country         String?             // Uganda, Ghana, Kenya
  defaultCurrency String   @default("UGX") // UGX, GHS, KES — derived from country, overridable
  parentId        String?
  parent      Tenant?  @relation("TenantHierarchy", fields: [parentId], references: [id])
  children    Tenant[] @relation("TenantHierarchy")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  farmerGroups FarmerGroup[]
  farmerProfiles FarmerProfile[]
  vslaGroups  VslaGroup[]
  companies   Company[]
  paymentAccounts PaymentAccount[]
  moduleEntitlements ModuleEntitlement[]
  subscriptions     Subscription[]
  loanProducts      LoanProduct[]
  apiKeys     ApiKey[]
  accounts         Account[]
  journalEntries   JournalEntry[]
  produceIntakes   ProduceIntake[]
  cooperativePayments CooperativePayment[]
  invoices         Invoice[]
  usageRecords     UsageRecord[]
  paymentTransactions PaymentTransaction[]
  trainings        Training[]
  surveys          Survey[]
  consignments     Consignment[]
  deliveries       Delivery[]
  messages             Message[]
  feedback             Feedback[]
  satelliteImages      SatelliteImage[]
  ndvTimeSeries        NdvTimeSeries[]
  rainfallRecords      RainfallRecord[]
  deforestationAlerts  DeforestationAlert[]
  carbonFootprints     CarbonFootprint[]
  carbonProjects       CarbonProject[]           @relation("TenantCarbonProjects")
  carbonCredits        CarbonCredit[]            @relation("TenantCarbonCredits")
  carbonVerifications  CarbonVerification[]      @relation("TenantCarbonVerifications")
  carbonProjectMethodologies CarbonProjectMethodology[] @relation("TenantCarbonProjectMethodologies")
  plots                Plot[]                    @relation("TenantPlots")
  plotSeasons          PlotSeason[]              @relation("TenantPlotSeasons")
  plotVerifications    PlotVerification[]        @relation("TenantPlotVerifications")
  plotDocuments        PlotDocument[]            @relation("TenantPlotDocuments")
  mfiPartners         MfiPartner[]             @relation("TenantMfiPartners")
  mfiLoanProducts     MfiLoanProduct[]         @relation("TenantMfiLoanProducts")
  mfiLoans            MfiLoan[]                @relation("TenantMfiLoans")
  mfiLoanSchedules    MfiLoanSchedule[]        @relation("TenantMfiLoanSchedules")
  mfiRepayments       MfiRepayment[]           @relation("TenantMfiRepayments")
  cbamCalculations     CbamCalculation[]
  exchangeRates        ExchangeRate[]  @relation("TenantExchangeRates")
  escrows             Escrow[]       @relation("TenantEscrow")
  settlements         Settlement[]    @relation("TenantSettlement")
  cbamReports          CbamReport[]
  rainforestCertifications RainforestCertification[]
  globalGapCertifications  GlobalGapCertification[]
  productBatches       ProductBatch[]
  traceEvents          TraceEvent[]
  farmPassports        FarmPassport[]
  costOfCultivations   CostOfCultivation[]
  notificationTemplates  NotificationTemplate[] @relation("TenantNotifications")
  notifications         Notification[]       @relation("TenantNotifRecords")
  notificationPreferences NotificationPreference[] @relation("TenantNotifPrefs")
  webhookEndpoints     WebhookEndpoint[]     @relation("TenantWebhooks")
  warehouses           Warehouse[]           @relation("TenantWarehouses")
  stockItems           StockItem[]           @relation("TenantStockItems")
  stockMovements       StockMovement[]       @relation("TenantStockMovements")
  gradeDefinitions     GradeDefinition[]     @relation("TenantGradeDefs")
  qualityInspections   QualityInspection[]   @relation("TenantQualityInspections")
  contracts            Contract[]            @relation("TenantContracts")
  vehicles             Vehicle[]             @relation("TenantVehicles")
  shipments            Shipment[]            @relation("TenantShipments")
  partners             Partner[]             @relation("TenantPartners")
  commissionRules      CommissionRule[]      @relation("TenantCommissionRules")
  commissionSettlements CommissionSettlement[] @relation("TenantCommissionSettlements")
  bulkOperations       BulkOperation[]       @relation("TenantBulkOps")
  dashboardWidgets     DashboardWidget[]     @relation("TenantDashWidgets")
  reportTemplates      ReportTemplate[]      @relation("TenantReportTemplates")
  scheduledReports     ScheduledReport[]     @relation("TenantScheduledReports")
  translations         Translation[]         @relation("TenantTranslations")
  brandingConfigs      BrandingConfig[]      @relation("TenantBranding")
  inputDealers         InputDealer[]
  inputProducts        InputProduct[]
  inputRequests        InputRequest[]
  marketProducts       MarketProduct[]
  marketMatches        MarketMatch[]
  fileAttachments      FileAttachment[]
  ussdSessions         UssdSession[]
  ivrCampaigns         IvrCampaign[]
  smsBroadcasts        SmsBroadcast[]
  vslaLoans            VslaLoan[]
  vslaLoanRepayments   VslaLoanRepayment[]
  vslaMeetings         VslaMeeting[]
  vslaAttendances      VslaAttendance[]
  exportJobs           ExportJob[]            @relation("TenantExportJob")
  transporters         Transporter[]          @relation("TenantTransporters")
  transportVehicles    TransportVehicle[]     @relation("TenantTransportVehicles")
  transportRequests    TransportRequest[]     @relation("TenantTransportRequests")
  transportTrips       TransportTrip[]        @relation("TenantTransportTrips")
  transportCharges     TransportCharge[]      @relation("TenantTransportCharges")
  ccrpEnrollments      CcrpEnrollment[]        @relation("TenantCcrpEnrollments")
  // ─── Impact Engine (6-week sprint) ───
  impactBaselines      ImpactBaseline[]       @relation("TenantImpactBaselines")
  impactEvents         ImpactEvent[]          @relation("TenantImpactEvents")
  impactKpiSnapshots   ImpactKpiSnapshot[]    @relation("TenantImpactKpiSnapshots")
  practiceAdoptions    PracticeAdoption[]     @relation("TenantPracticeAdoptions")
  climateResilienceScores ClimateResilienceScore[] @relation("TenantClimateResilienceScores")
}

// --- USERS & AUTH ---

model User {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  role          String   // SUPER_ADMIN, COUNTRY_ADMIN, TENANT_ADMIN, AGENT, EXTENSION_OFFICER, CBT, CASUAL, FARMER, VSLA_MEMBER
  email         String?
  phone         String   @unique
  passwordHash  String?
  firstName     String
  lastName      String
  avatarUrl     String?
  isActive      Boolean  @default(true)
  lastLogin     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agentAssignments   AgentAssignment[]
  auditLogs          AuditLog[]
  farmerProfiles     FarmerProfile[]
  notifications      Notification[] @relation("UserNotifications")
  notificationPreferences NotificationPreference[] @relation("UserNotifPrefs")
  managedWarehouse   Warehouse?       @relation("WarehouseManager")
  qualityInspections QualityInspection[] @relation("QualityInspector")
  apiKeys            ApiKey[]            @relation("UserApiKeys")
  carbonProjects     CarbonProject[]     @relation("UserCarbonProjects")
}

model AgentAssignment {
  id        String   @id @default(cuid())
  agentId   String
  agent     User     @relation(fields: [agentId], references: [id])
  groupId   String
  groupType String   // FARMER_GROUP, VSLA
  assignedAt DateTime @default(now())
}

// --- GEOGRAPHIC HIERARCHY ---

model Region {
  id        String     @id @default(cuid())
  name      String
  country   String
  createdAt DateTime   @default(now())
  subRegions SubRegion[]
}

model SubRegion {
  id        String    @id @default(cuid())
  name      String
  regionId  String
  region    Region    @relation(fields: [regionId], references: [id])
  districts District[]
}

model District {
  id          String       @id @default(cuid())
  name        String
  subRegionId String
  subRegion   SubRegion    @relation(fields: [subRegionId], references: [id])
  constituencies Constituency[]
}

model Constituency {
  id          String       @id @default(cuid())
  name        String
  districtId  String
  district    District     @relation(fields: [districtId], references: [id])
  subCounties SubCounty[]
}

model SubCounty {
  id            String    @id @default(cuid())
  name          String
  constituencyId String
  constituency   Constituency @relation(fields: [constituencyId], references: [id])
  parishes      Parish[]
}

model Parish {
  id          String     @id @default(cuid())
  name        String
  subCountyId String
  subCounty   SubCounty  @relation(fields: [subCountyId], references: [id])
  villages    Village[]
}

model Village {
  id        String   @id @default(cuid())
  name      String
  parishId  String
  parish    Parish   @relation(fields: [parishId], references: [id])
  farmers   FarmerProfile[]
}

// --- COOPERATIVES & FARMER GROUPS ---

model Company {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  type        String?  // Cooperative, Agribusiness, etc.
  contactPerson String?
  phone       String?
  email       String?
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  farmerGroups FarmerGroup[]
}

model FarmerGroup {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id])
  name        String
  contactPerson String?
  location    String?
  isVsla      Boolean  @default(false)
  vslaSettings Json?    // shareValue, loanRate, maxLoanAmount, fines, welfare
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  farmers    FarmerProfile[]
  vslaGroups VslaGroup[]
}

// --- FARMER PROFILING ---

model FarmerProfile {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  groupId         String?
  group           FarmerGroup? @relation(fields: [groupId], references: [id])
  farmerCode      String?  @unique
  firstName       String
  lastName        String
  phone           String
  gender          String?  // Male, Female, Other
  dateOfBirth     DateTime?
  education       String?  // Primary, Secondary, UG, PG, Other
  maritalStatus   String?
  nationalIdType  String?  // National ID, Driving License, Passport
  nationalIdNo    String?
  photoUrl        String?
  isCertified     Boolean  @default(false)
  certificationType String?
  memberType      String   // General, Commercial
  status          String   @default("ACTIVE") // ACTIVE, INACTIVE

  // Location
  villageId       String?
  village         Village? @relation(fields: [villageId], references: [id])
  gpsLatitude     Float?
  gpsLongitude    Float?

  // Family
  familyMembers   Int?
  childrenUnder18 Int?
  schoolGoingChildren Int?
  spouseName      String?

  // Bank
  bankName        String?
  bankAccountNo   String?
  bankBranch      String?

  // Farm
  farmSize        Float?   // hectares
  farmOwnership   String?  // Owned, Rent, Lease
  mainCrops       String?  // JSON array of crop names
  livestockTypes  String?  // JSON array

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  children        ChildProfile[]
  farms           FarmLand[]
  creditScores    CreditScore[]
  savings         VslaSaving[]
  vslaLoans       VslaLoan[]
  vslaAttendance  VslaAttendance[]
  trainings       TrainingAttendance[]
  purchases       Purchase[]
  sales           Sale[]
  vslaMemberships VslaMember[]
  farmVisits      FarmVisit[]      @relation("FarmerVisits")
  impactAssessments ImpactAssessment[] @relation("FarmerImpact")
  eudrCompliances EudrCompliance[]  @relation("FarmerEudr")
  cbamReports     CbamReport[]      @relation("FarmerCbam")
  rainforestCerts RainforestCertification[] @relation("FarmerRainforest")
  globalGapCerts  GlobalGapCertification[] @relation("FarmerGlobalGap")
  produceIntakes        ProduceIntake[]        @relation("FarmerIntake")
  cooperativePayments   CooperativePayment[]    @relation("FarmerCoopPayment")
  productBatches       ProductBatch[]         @relation("FarmerBatches")
  farmPassport         FarmPassport?          @relation("FarmerPassport")
  plots                Plot[]                 @relation("FarmerPlots")
  ccrpEnrollments      CcrpEnrollment[]        @relation("FarmerCcrpEnrollments")
  // ─── Impact Engine (6-week sprint) ───
  impactBaseline       ImpactBaseline?         @relation("FarmerImpactBaseline")
  impactEvents         ImpactEvent[]           @relation("FarmerImpactEvents")
  impactKpiSnapshots   ImpactKpiSnapshot[]     @relation("FarmerImpactKpiSnapshots")
  practiceAdoptions    PracticeAdoption[]      @relation("FarmerPracticeAdoptions")
  climateResilienceScores ClimateResilienceScore[] @relation("FarmerClimateResilienceScores")
}

model ChildProfile {
  id          String   @id @default(cuid())
  farmerId    String
  farmer      FarmerProfile @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String
  gender      String?
  dateOfBirth DateTime?
  schoolName  String?
  schoolId    String?
  createdAt   DateTime @default(now())
}

model FarmLand {
  id          String   @id @default(cuid())
  farmerId    String
  farmer      FarmerProfile @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  name        String
  sizeHectares Float?
  latitude    Float?
  longitude   Float?
  landOwnership String?
  waterSource String?
  soilFertility String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cultivations Cultivation[]
  polygonPoints FarmPolygon[]
}

model Cultivation {
  id              String   @id @default(cuid())
  farmId          String
  farm            FarmLand @relation(fields: [farmId], references: [id], onDelete: Cascade)
  cropName        String
  variety         String?
  season          String?
  sowingDate      DateTime?
  estimatedYield  Float?
  actualYield     Float?
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// --- VSLA MANAGEMENT ---

model VslaGroup {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  groupId         String?
  group           FarmerGroup? @relation(fields: [groupId], references: [id])
  name            String
  shareValue      Float
  loanRate        Float    // percentage
  maxLoanAmount   Float
  fines           Float    @default(0)
  welfareAmount   Float    @default(0)
  meetingFrequency String?  // Weekly, Bi-weekly, Monthly
  isActive        Boolean  @default(true)
  isClosed        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members         VslaMember[]
  savings         VslaSaving[]
  loans           VslaLoan[]
  meetings        VslaMeeting[]
  transactions    VslaTransaction[]
  welfarePayments WelfarePayment[]
}

model VslaMember {
  id          String   @id @default(cuid())
  vslaGroupId String
  vslaGroup   VslaGroup @relation(fields: [vslaGroupId], references: [id])
  farmerId    String
  farmer      FarmerProfile @relation(fields: [farmerId], references: [id])
  memberId    String   @unique // auto-generated member ID
  isAdmin     Boolean  @default(false)
  isKeyholder Boolean  @default(false)
  sharesOwned Int      @default(0)
  joinedAt    DateTime @default(now())
}

model VslaSaving {
  id              String   @id @default(cuid())
  vslaGroupId     String
  vslaGroup       VslaGroup @relation(fields: [vslaGroupId], references: [id])
  farmerId        String
  farmer          FarmerProfile @relation(fields: [farmerId], references: [id])
  memberId        String?
  amount          Float
  sharesBought    Int      @default(1)
  savedOnBehalfOf String?  // member ID if saved for another
  transactionRef  String?
  status          String   @default("COMPLETED") // PENDING, COMPLETED, FAILED
  createdAt       DateTime @default(now())
}

model VslaLoan {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  vslaGroupId     String
  vslaGroup       VslaGroup @relation(fields: [vslaGroupId], references: [id])
  farmerId        String
  farmer          FarmerProfile @relation(fields: [farmerId], references: [id])
  memberId        String?
  amount          Float
  interestRate    Float
  totalRepayable  Float
  amountRepaid    Float    @default(0)
  purpose         String?  // Savings, Welfare
  status          String   @default("PENDING") // PENDING, APPROVED, DISBURSED, REPAID, REJECTED, OVERDUE
  approvedByIds   String?  // JSON array of approver IDs
  loanDate        DateTime @default(now())
  requestedAt     DateTime @default(now())
  approvedAt      DateTime?
  disbursedAt     DateTime?
  dueDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  repayments      VslaLoanRepayment[]
}

model VslaLoanRepayment {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  loanId      String
  loan        VslaLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  amount      Float
  repaidOnBehalfOf String?
  transactionRef String?
  createdAt   DateTime @default(now())
}

model VslaMeeting {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  vslaGroupId     String
  vslaGroup       VslaGroup @relation(fields: [vslaGroupId], references: [id])
  agenda          String?
  meetingDate     DateTime
  meetingType     String?
  startTime       String?
  endTime         String?
  notes           String?
  status          String   @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, CONCLUDED
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attendance      VslaAttendance[]
}

model VslaAttendance {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  meetingId   String
  meeting     VslaMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  farmerId    String
  farmer      FarmerProfile @relation(fields: [farmerId], references: [id])
  markedBy    String?  // if marked on behalf
  present     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([meetingId, farmerId])
}

model VslaTransaction {
  id              String   @id @default(cuid())
  vslaGroupId     String
  vslaGroup       VslaGroup @relation(fields: [vslaGroupId], references: [id])
  type            String   // SAVING, LOAN_DISBURSEMENT, LOAN_REPAYMENT, WELFARE, FINE, SHARE_REDEEM
  amount          Float
  description     String?
  transactionRef  String?
  status          String   @default("COMPLETED")
  createdAt       DateTime @default(now())
}

model WelfarePayment {
  id          String   @id @default(cuid())
  vslaGroupId String
  vslaGroup   VslaGroup @relation(fields: [vslaGroupId], references: [id])
  farmerId    String?
  amount      Float
  reason      String?
  createdAt   DateTime @default(now())
}

// --- LOAN MANAGEMENT (Institutional) ---

model LoanProduct {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  name            String
  interestRate    Float
  maxAmount       Float
  minAmount       Float
  maxDuration     Int      // months
  gracePeriod     Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  applications    LoanApplication[]
}

model LoanApplication {
  id              String   @id @default(cuid())
  loanProductId   String
  loanProduct     LoanProduct @relation(fields: [loanProductId], references: [id])
  farmerId        String?
  applicantName   String
  applicantPhone  String
  amount          Float
  purpose         String?
  status          String   @default("PENDING") // PENDING, LEVEL1_APPROVED, LEVEL2_APPROVED, APPROVED, DISBURSED, REJECTED, COMPLETED, OVERDUE
  level1ApprovedBy String?
  level2ApprovedBy String?
  level1ApprovedAt DateTime?
  level2ApprovedAt DateTime?
  disbursedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// --- INPUT AGGREGATION ---

model InputDealer {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  phone     String?
  location  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products   InputProduct[]
  requests   InputRequest[]
}

model InputProduct {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  dealerId    String
  dealer      InputDealer @relation(fields: [dealerId], references: [id])
  name        String
  category    String?  // Seeds, Fertilizer, Pesticide, Equipment
  variety     String?
  unit        String?  // Kg, Bags, Litres
  unitPrice   Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InputRequest {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  dealerId    String?
  dealer      InputDealer? @relation(fields: [dealerId], references: [id])
  farmerId    String?
  farmerName  String
  farmerPhone String
  product     String
  quantity    String
  unitPrice   Float?
  totalPrice  Float?
  status      String   @default("PENDING") // PENDING, CONFIRMED, DELIVERED, CANCELLED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- MARKETPLACE ---

model MarketProduct {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  sellerId    String?  // farmer or group ID
  sellerName  String
  commodity   String   // Maize, Coffee, Rice, etc.
  variety     String?
  quantity    String
  unitPrice   Float?
  location    String?
  status      String   @default("AVAILABLE") // AVAILABLE, MATCHED, SOLD
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  matches     MarketMatch[]
}

model MarketMatch {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  productId       String?
  product         MarketProduct? @relation(fields: [productId], references: [id])
  buyerName       String
  buyerPhone      String?
  quantity        String
  pricePerUnit    Float?
  totalValue      Float?
  status          String   @default("PENDING") // PENDING, CONFIRMED, DELIVERED, PAID, CANCELLED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// --- PURCHASES & CONSIGNMENTS ---

model Purchase {
  id          String   @id @default(cuid())
  groupId     String?
  farmerId    String?
  farmer      FarmerProfile? @relation(fields: [farmerId], references: [id])
  commodity   String
  variety     String?
  quantity    String
  unitPrice   Float?
  totalAmount Float?
  status      String   @default("PENDING") // PENDING, REVIEWED, APPROVED, PAID
  initiatedBy String?
  reviewedBy  String?
  approvedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Consignment {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  product     String
  quantity    String
  source      String?
  destination String?
  status      String   @default("DRAFT") // DRAFT, DISPATCHED, CHECKED_IN, RECEIVED, APPROVED, PAID
  totalValue  Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- PAYMENTS ---

model PaymentAccount {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  accountName String
  accountType String   @default("MERCHANT")
  email       String?
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payments    Payment[]
}

model Payment {
  id              String   @id @default(cuid())
  paymentAccountId String?
  paymentAccount  PaymentAccount? @relation(fields: [paymentAccountId], references: [id])
  type            String   // CASUAL, BULK_PURCHASE, BULK_DISBURSEMENT, MARKETPLACE, VSLA
  recipientName   String
  recipientPhone  String
  amount          Float
  description     String?
  transactionRef  String?
  status          String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions          PaymentTransaction[]   @relation("PaymentTransactions")
}

// --- TRAINING ---

model Training {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  topic       String
  description String?
  date        DateTime
  location    String?
  trainerName String?
  createdAt   DateTime @default(now())

  attendance  TrainingAttendance[]
}

model TrainingAttendance {
  id          String   @id @default(cuid())
  trainingId  String
  training    Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  farmerId    String
  farmer      FarmerProfile @relation(fields: [farmerId], references: [id])
  attended    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// --- CREDIT SCORING ---

model CreditScore {
  id              String   @id @default(cuid())
  farmerId        String
  farmer          FarmerProfile @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  demographicsScore Float?
  assetScore      Float?
  cropScore       Float?
  financialScore  Float?
  totalScore      Float?
  scoreDate       DateTime @default(now())
}

// --- SURVEYS ---

model Survey {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  title       String
  description String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())

  questions   SurveyQuestion[]
  responses   SurveyResponse[]
}

model SurveyQuestion {
  id        String  @id @default(cuid())
  surveyId  String
  survey    Survey  @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  question  String
  type      String  // TEXT, RADIO, CHECKBOX, NUMBER
  options   String? // JSON array
  sortOrder Int     @default(0)
}

model SurveyResponse {
  id          String   @id @default(cuid())
  surveyId    String
  survey      Survey   @relation(fields: [surveyId], references: [id])
  respondentId String?
  answers     String   // JSON
  createdAt   DateTime @default(now())
}

// --- COMMUNICATION ---

model Message {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  type        String   // SMS, EMAIL, IVR
  recipient   String
  content     String
  status      String   @default("PENDING") // PENDING, SENT, DELIVERED, FAILED
  sentAt      DateTime?
  createdAt   DateTime @default(now())
}

// --- MODULE ENTITLEMENT & BILLING ---

model ModuleEntitlement {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  moduleCode  String   // VSLA, MARKETPLACE, TRAINING, TRACE, etc.
  isEnabled   Boolean  @default(true)
  config      String?  // JSON for module-specific settings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, moduleCode])
}

model Subscription {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  plan        String   // BASIC, STANDARD, ENTERPRISE
  amount      Float
  billingCycle String  // MONTHLY, ANNUAL
  status      String   @default("ACTIVE")
  startDate   DateTime @default(now())
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- API KEYS ---

model ApiKey {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  name            String
  key             String   @unique
  keyPrefix       String                          // First 8 chars for display
  userId          String?
  user            User?    @relation("UserApiKeys", fields: [userId], references: [id])
  scopes          String   @default("read")        // JSON array of scopes e.g. ["farmers:read","purchases:read"]
  rateLimitRpm    Int      @default(60)             // Requests per minute
  rateLimitRpd    Int      @default(10000)          // Requests per day
  expiresAt       DateTime?
  lastUsedAt      DateTime?
  totalRequests   Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  usageLogs       ApiKeyUsageLog[]
}

model ApiKeyUsageLog {
  id          String   @id @default(cuid())
  apiKeyId    String
  apiKey      ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  method      String
  path        String
  statusCode  Int
  responseMs  Int
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

// --- AUDIT LOG ---

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entityType  String?
  entityId    String?
  details     String?
  ipAddress   String?
  createdAt   DateTime @default(now())
}

// --- RBAC: PERMISSIONS ---

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique  // e.g. "farmers:read", "vsla:approve_loans"
  module      String   // e.g. "farmers", "vsla", "compliance"
  action      String   // read, create, update, delete, approve, manage
  description String?
  createdAt   DateTime @default(now())

  roles       RolePermission[]
}

model RolePermission {
  id            String     @id @default(cuid())
  role          String     // SUPER_ADMIN, COUNTRY_ADMIN, TENANT_ADMIN, AGENT, EXTENSION_OFFICER, CBT, CASUAL, FARMER, VSLA_MEMBER
  permissionId  String
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
}

// --- SALES ---

model Sale {
  id              String   @id @default(cuid())
  farmerId        String?
  farmer          FarmerProfile? @relation(fields: [farmerId], references: [id])
  customerId      String?
  customerName    String?
  product         String
  quantity        String
  unitPrice       Float?
  totalAmount     Float?
  status          String   @default("COMPLETED")
  createdAt       DateTime @default(now())
}

// --- COMMODITIES ---

model Commodity {
  id          String   @id @default(cuid())
  name        String
  category    String?  // Crop, Livestock, Forestry, Fishery
  unit        String?  // Kg, Litres, Bags
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// --- DELIVERIES ---

model Delivery {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  relatedId   String?
  relatedType String?  // PURCHASE, CONSIGNMENT, INPUT_REQUEST
  status      String   @default("PENDING") // PENDING, IN_TRANSIT, DELIVERED
  driverName  String?
  vehicleReg  String?
  dispatchedAt DateTime?
  deliveredAt DateTime?
  createdAt   DateTime @default(now())
}

// --- FEEDBACK ---

model Feedback {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  farmerId    String?
  category    String?
  message     String
  status      String   @default("NEW") // NEW, REVIEWED, RESOLVED
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
}

// --- FARM VISITS (Individual Training - EKIBBO requirement) ---

model FarmVisit {
  id            String   @id @default(cuid())
  farmerId      String?
  farmer        FarmerProfile? @relation("FarmerVisits", fields: [farmerId], references: [id])
  extensionOfficerId String?
  visitDate     DateTime
  topic         String
  observations  String?
  recommendations String?
  followUpDate  DateTime?
  status        String   @default("COMPLETED") // SCHEDULED, COMPLETED, CANCELLED
  createdAt     DateTime @default(now())
}

// --- IMPACT ASSESSMENT (EKIBBO requirement) ---

model ImpactAssessment {
  id              String   @id @default(cuid())
  farmerId        String?
  farmer          FarmerProfile? @relation("FarmerImpact", fields: [farmerId], references: [id])
  assessmentDate  DateTime @default(now())
  category        String   // Income, Yield, QualityOfLife, TrainingImpact, MarketAccess
  response        String   // JSON - answers to assessment questions
  score           Float?
  notes           String?
  conductedBy     String?
  createdAt       DateTime @default(now())
}

// --- FILE ATTACHMENTS (EKIBBO requirement - proof before payment) ---

model FileAttachment {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  relatedId     String?  // polymorphic - can be payment, purchase, training, etc.
  relatedType   String?  // PAYMENT, PURCHASE, TRAINING, FARM_VISIT, CONSENT_FORM
  fileName      String
  fileType      String?  // image/png, application/pdf, etc.
  fileSize      Int?
  fileUrl       String?
  uploadedBy    String?
  description   String?
  createdAt     DateTime @default(now())
}

// --- FARM POLYGON / GPS POINTS (EKIBBO - 5+ GPS points per farm) ---

model FarmPolygon {
  id        String   @id @default(cuid())
  farmId    String
  farm      FarmLand @relation(fields: [farmId], references: [id], onDelete: Cascade)
  pointOrder Int
  latitude  Float
  longitude Float
  altitude  Float?
  createdAt DateTime @default(now())
}

// --- COMPLIANCE: EUDR (EU Deforestation Regulation) ---

model EudrCompliance {
  id              String   @id @default(cuid())
  farmerId        String?
  farmer          FarmerProfile? @relation("FarmerEudr", fields: [farmerId], references: [id])
  plotId          String   @unique
  plotName        String
  geolocation     String   // GeoJSON polygon
  areaHectares    Float
  commodities     String   // JSON array of commodities
  deforestationFree Boolean @default(false)
  deforestationDate DateTime?
  legalDocuments  String?  // JSON array of document references
  riskAssessment  String?  // LOW, MEDIUM, HIGH
  dueDiligenceRef String?
  status          String   @default("PENDING") // PENDING, VERIFIED, REJECTED, EXPIRED
  verifiedBy      String?
  verifiedAt      DateTime?
  expiryDate      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  deforestationAlerts  DeforestationAlert[]  @relation("EudrDeforestation")
  documents           EudrDocument[]          @relation("EudrDocuments")
  auditLogs           EudrAuditLog[]          @relation("EudrAuditLogs")
}

// --- COMPLIANCE: CBAM (Carbon Border Adjustment Mechanism) ---

model CbamReport {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  farmerId        String?
  farmer          FarmerProfile? @relation("FarmerCbam", fields: [farmerId], references: [id])
  reportingPeriod String   // e.g. "2026-Q1"
  commodity       String
  quantityTonnes  Float
  embeddedEmissions Float  // tCO2e per tonne
  totalEmissions  Float    // total tCO2e
  certificationType String? // Organic, Conventional, etc.
  carbonCredits   Float?
  status          String   @default("DRAFT") // DRAFT, SUBMITTED, VERIFIED, REJECTED
  submittedBy     String?
  submittedAt     DateTime?
  verifiedBy      String?
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cbamCalculation  CbamCalculation?  @relation("CbamCalc")
}

// --- COMPLIANCE: RAINFOREST ALLIANCE ---

model RainforestCertification {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  farmerId        String?
  farmer          FarmerProfile? @relation("FarmerRainforest", fields: [farmerId], references: [id])
  certificateNo   String   @unique
  certificationLevel String // RA Standard, RA Climate, RA/UTZ
  issueDate       DateTime
  expiryDate      DateTime
  auditDate       DateTime?
  auditorName     String?
  auditScore      Float?
  criticalFindings Int @default(0)
  majorFindings   Int @default(0)
  minorFindings   Int @default(0)
  status          String   @default("ACTIVE") // ACTIVE, SUSPENDED, REVOKED, EXPIRED
  nextAuditDate   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// --- COMPLIANCE: GLOBALG.A.P. ---

model GlobalGapCertification {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  farmerId        String?
  farmer          FarmerProfile? @relation("FarmerGlobalGap", fields: [farmerId], references: [id])
  ggnNumber       String   @unique
  scope           String   // Crops, Flowers, Aquaculture, etc.
  version         String?  // e.g. "v6.0"
  option          String   // All Farm Base (AFB), Sub-Scope, Single Site
  issueDate       DateTime
  expiryDate      DateTime
  auditDate       DateTime?
  auditorName     String?
  compliancePercentage Float?
  status          String   @default("ACTIVE") // ACTIVE, SUSPENDED, REVOKED, EXPIRED
  nextAuditDate   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// --- CHANNEL SIMULATOR: USSD SESSIONS ---

model UssdSession {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  sessionId   String   @unique
  phoneNumber String
  currentStep String
  inputData   String?  // JSON - accumulated input data
  status      String   @default("ACTIVE") // ACTIVE, COMPLETED, TIMEOUT
  createdAt   DateTime @default(now())
  completedAt DateTime?
}

// --- CHANNEL SIMULATOR: IVR CAMPAIGN ---

model IvrCampaign {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  script      String   // JSON - IVR call flow script
  targetGroup String?  // farmer group or segment
  status      String   @default("DRAFT") // DRAFT, SCHEDULED, RUNNING, COMPLETED
  scheduledAt DateTime?
  totalCalls  Int      @default(0)
  completedCalls Int   @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- CHANNEL SIMULATOR: SMS BROADCAST ---

model SmsBroadcast {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  message     String
  recipientCount Int   @default(0)
  status      String   @default("DRAFT") // DRAFT, SCHEDULED, SENT, FAILED
  scheduledAt DateTime?
  sentAt      DateTime?
  createdBy   String?
  createdAt   DateTime @default(now())
}

// --- COOPERATIVE ERP: DOUBLE-ENTRY ACCOUNTING ---

model Account {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  code          String   // e.g., "1001", "2001"
  name          String   // e.g., "Cash", "Accounts Payable"
  type          String   // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  normalBalance String   @default("DEBIT") // DEBIT or CREDIT
  parentId      String?
  parent        Account? @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      Account[] @relation("AccountHierarchy")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  journalLines JournalLine[]
}

model JournalEntry {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  date        DateTime @default(now())
  description String
  reference   String?  // e.g., "INTAKE-2024-001", "PAY-2024-001"
  status      String   @default("DRAFT") // DRAFT, POSTED, REVERSED
  createdBy   String?
  postedBy    String?
  postedAt    DateTime?
  reversedBy  String?
  reversedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines        JournalLine[]
  settlement    Settlement?    @relation("SettlementJournal")
}

model JournalLine {
  id            String       @id @default(cuid())
  journalEntryId String
  journalEntry  JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId     String
  account       Account      @relation(fields: [accountId], references: [id])
  entryType     String       // DEBIT or CREDIT
  amount        Float
  description   String?
}

// --- COOPERATIVE ERP: PRODUCE INTAKE ---

model ProduceIntake {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  cooperativeId   String?
  farmerId        String?
  farmer          FarmerProfile? @relation("FarmerIntake", fields: [farmerId], references: [id])
  commodity       String
  variety         String?
  quantityKg      Float
  moistureContent Float?
  grade           String?  // A, B, C, Premium, Standard
  pricePerKg      Float
  totalAmount     Float
  intakeDate      DateTime @default(now())
  status          String   @default("DRAFT") // DRAFT, WEIGHED, GRADED, ACCEPTED, REJECTED, STORED
  receivedBy      String?
  warehouse       String?
  qualityNotes    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payments        CooperativePayment[]
}

// --- COOPERATIVE ERP: FARMER PAYMENTS ---

model CooperativePayment {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  cooperativeId   String?
  intakeId        String?
  intake          ProduceIntake? @relation(fields: [intakeId], references: [id])
  farmerId        String?
  farmer          FarmerProfile? @relation("FarmerCoopPayment", fields: [farmerId], references: [id])
  phase           String   // FIRST, FINAL
  grossAmount     Float
  deductions      String?  // JSON array of {type, amount, description}
  netAmount       Float
  paymentMethod   String?  // MOBILE_MONEY, BANK, CASH
  status          String   @default("PENDING") // PENDING, PROCESSING, PAID, FAILED
  paidAt          DateTime?
  transactionRef  String?
  paidBy          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// --- BILLING: INVOICES ---

model Invoice {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  invoiceNumber String   @unique
  subscriptionId String?
  plan          String   // FREE, BASIC, STANDARD, ENTERPRISE, CUSTOM
  billingCycle  String   // MONTHLY, QUARTERLY, ANNUAL
  items         String   // JSON array of {description, amount, quantity, total}
  subtotal      Float
  tax           Float    @default(0)
  taxRate       Float    @default(0)
  total         Float
  currency      String   @default("USD")
  status        String   @default("DRAFT") // DRAFT, PENDING, PAID, OVERDUE, CANCELLED, PARTIALLY_PAID
  dueDate       DateTime
  paidAt        DateTime?
  paidAmount    Float    @default(0)
  reminderCount Int      @default(0)
  lastReminderAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// --- BILLING: USAGE TRACKING ---

model UsageRecord {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  eventType   String   // FARMER_CREATED, USER_CREATED, API_CALL, SMS_SENT, etc.
  count       Int      @default(1)
  period      String   // "2026-06" (YYYY-MM format)
  recordedAt  DateTime @default(now())
}

// --- PAYMENT TRANSACTIONS (Enhanced) ---

model PaymentTransaction {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  paymentId         String?
  payment           Payment? @relation("PaymentTransactions", fields: [paymentId], references: [id])
  provider          String   // MPAY, AINTEL, MTN_MOMO, MPESA, BANK_TRANSFER, MANUAL
  providerTxnRef    String?  // Provider's transaction reference
  type              String   // COLLECTION, DISBURSEMENT
  amount            Float
  currency          String   // UGX, GHS, KES, USD
  recipientPhone    String
  recipientName     String
  status            String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED, CANCELLED, REFUNDED
  failureReason     String?
  initiatedBy       String?
  completedAt       DateTime?
  callbackReceived  Boolean  @default(false)
  callbackBody      String?  // Raw callback JSON
  metadata          String?  // JSON for additional data
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  escrowAsPayment    Escrow?       @relation("EscrowPayment")
  settlementAsPayment Settlement?  @relation("SettlementPayment")
}

// --- V1 MIGRATION TRACKING ---

model MigrationLog {
  id              String   @id @default(cuid())
  tableName       String   // V1 table name
  totalRecords    Int
  migratedRecords Int
  failedRecords   Int
  skippedRecords  Int
  status          String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, FAILED, PARTIAL
  startedAt       DateTime?
  completedAt     DateTime?
  errorLog        String?  // JSON array of errors
  executedBy      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model IdMapping {
  id          String   @id @default(cuid())
  tableName   String   // V1 table name
  v1Id        String   // Original V1 ID
  v3Id        String   // New V3 ID
  createdAt   DateTime @default(now())

  @@unique([tableName, v1Id])
}

// ============================================
// PHASE 3 — SATELLITE, CARBON, TRACEABILITY
// ============================================

// --- SATELLITE INTELLIGENCE ---

model SatelliteImage {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  source          String   // SENTINEL2, LANDSAT8, LANDSAT9, CHIRPS
  farmId          String?
  acquisitionDate DateTime
  bbox            String   // JSON: [west, south, east, north]
  cloudCover      Float    @default(0)
  resolution      Float
  thumbnailUrl    String?
  downloadUrl     String?
  processedData   String?  // JSON: vegetation indices, land cover, etc.
  createdAt       DateTime @default(now())
}

model NdvTimeSeries {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  farmId          String
  plotId          String?
  date            String
  ndviValue       Float
  eviValue        Float?
  cloudCover      Float    @default(0)
  source          String   @default("SENTINEL2")
  createdAt       DateTime @default(now())
}

model RainfallRecord {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  farmId          String?
  latitude        Float
  longitude       Float
  date            String   // YYYY-MM-DD
  rainfallMm      Float
  isChirps        Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model DeforestationAlert {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  eudrComplianceId  String?
  eudrCompliance    EudrCompliance? @relation("EudrDeforestation", fields: [eudrComplianceId], references: [id])
  farmId            String?
  severity          String   @default("NONE") // NONE, LOW, MEDIUM, HIGH, CRITICAL
