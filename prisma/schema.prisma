  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([partnerId])
}

model MfiLoan {
  id                  String    @id @default(cuid())
  tenantId            String
  tenant              Tenant    @relation("TenantMfiLoans", fields: [tenantId], references: [id])
  partnerId           String?
  partner             MfiPartner? @relation(fields: [partnerId], references: [id])
  loanProductId       String
  loanProduct         MfiLoanProduct @relation(fields: [loanProductId], references: [id])
  farmerId            String?
  applicantName       String
  applicantPhone      String
  amount              Decimal   @db.Decimal(18, 2)
  interestRate        Decimal   @db.Decimal(8, 4)
  durationMonths      Int
  gracePeriodMonths   Int
  purpose             String?
  collateralDetails   String?
  documents           String?   // JSON
  status              String    @default("PENDING") // PENDING | UNDER_REVIEW | APPROVED | REJECTED | DISBURSED | OVERDUE | REPAID
  approvedAmount      Decimal?  @db.Decimal(18, 2)
  approvedAt          DateTime?
  approvedBy          String?
  rejectionReason     String?
  disbursedAt         DateTime?
  disbursedBy         String?
  totalRepayment      Decimal?  @db.Decimal(18, 2)
  totalInterest       Decimal?  @db.Decimal(18, 2)
  totalPenalty        Decimal?  @db.Decimal(18, 2)
  totalPaid           Decimal?  @db.Decimal(18, 2)
  outstandingBalance  Decimal?  @db.Decimal(18, 2)
  nextPaymentDate     DateTime?
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  schedule    MfiLoanSchedule[]
  repayments  MfiRepayment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([loanProductId])
  @@index([partnerId])
  @@index([farmerId])
}

model MfiLoanSchedule {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation("TenantMfiLoanSchedules", fields: [tenantId], references: [id])
  loanId            String
  loan              MfiLoan  @relation(fields: [loanId], references: [id], onDelete: Cascade)
  installmentNumber Int
  dueDate           DateTime
  principalDue      Decimal  @db.Decimal(18, 2)
  interestDue       Decimal  @db.Decimal(18, 2)
  penaltyDue        Decimal  @default(0) @db.Decimal(18, 2)
  totalDue          Decimal  @db.Decimal(18, 2)
  principalPaid     Decimal  @default(0) @db.Decimal(18, 2)
  interestPaid      Decimal  @default(0) @db.Decimal(18, 2)
  penaltyPaid       Decimal  @default(0) @db.Decimal(18, 2)
  totalPaid         Decimal  @default(0) @db.Decimal(18, 2)
  status            String   @default("PENDING") // PENDING | OVERDUE | PARTIAL | PAID
  paidAt            DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([loanId, installmentNumber])
  @@index([tenantId])
  @@index([loanId])
  @@index([loanId, installmentNumber])
}

model MfiRepayment {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation("TenantMfiRepayments", fields: [tenantId], references: [id])
  loanId           String
  loan             MfiLoan  @relation(fields: [loanId], references: [id], onDelete: Cascade)
  scheduleId       String
  amount           Decimal  @db.Decimal(18, 2)
  principalAmount  Decimal  @db.Decimal(18, 2)
  interestAmount   Decimal  @db.Decimal(18, 2)
  penaltyAmount    Decimal  @db.Decimal(18, 2)
  paymentMethod    String?
  referenceNumber  String?
  receivedBy       String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId])
  @@index([loanId])
  @@index([scheduleId])
}

// ============================================
// CCRP (Cashew Crop Research Project) ENROLLMENT
// Tracks farmer enrollment, adopted practices, and history
// ============================================

model CcrpEnrollment {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant         @relation("TenantCcrpEnrollments", fields: [tenantId], references: [id])
  farmerId        String
  farmer          FarmerProfile  @relation("FarmerCcrpEnrollments", fields: [farmerId], references: [id], onDelete: Cascade)
  enrolledBy      String?
  enrolledByName  String?
  enrolledAt      DateTime @default(now())
  status          String   @default("ACTIVE")  // ACTIVE | SUSPENDED | GRADUATED | EXITED
  exitReason      String?                        // Graduate, Relocated, Deceased, Inactive
  exitedAt        DateTime?
  practices       String?                         // JSON array of adopted practice names, e.g. ["irrigation","agroforestry"]
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  history         CcrpEnrollmentHistory[]

  @@unique([tenantId, farmerId])
  @@index([tenantId])
  @@index([farmerId])
  @@index([status])
}

model CcrpEnrollmentHistory {
  id              String   @id @default(cuid())
  enrollmentId    String
  enrollment      CcrpEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  changedBy       String?
  changedByName   String?
  action          String                     // ENROLLED, PRACTICE_ADDED, PRACTICE_REMOVED, STATUS_CHANGED, NOTES_UPDATED
  previousValue   String?                    // JSON snapshot of relevant fields before change
  newValue        String?                    // JSON snapshot of relevant fields after change
  createdAt       DateTime @default(now())

  @@index([enrollmentId])
  @@index([action])
}
// ════════════════════════════════════════════════════════════
// IMPACT ENGINE (6-week sprint — Agrobase V3 Strategy)
//
// 5 new models that turn Agrobase from "operations platform" into
// "impact-native platform". Every transaction writes impact data.
//
//   ImpactBaseline        — captured once at enrolment, the comparison anchor
//   ImpactEvent           — hash-chained event ledger (Impact Passport)
//   ImpactKpiSnapshot     — nightly KPI computation per farmer (all 32 KPIs)
//   PracticeAdoption      — Farm5x practice adoption events (1M5C/M/K/T/D)
//   ClimateResilienceScore — 4-factor 0-100 score per farmer per month
// ════════════════════════════════════════════════════════════

model ImpactBaseline {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation("TenantImpactBaselines", fields: [tenantId], references: [id])
  farmerId          String   @unique
  farmer            FarmerProfile @relation("FarmerImpactBaseline", fields: [farmerId], references: [id], onDelete: Cascade)

  // Captured by extension officer at enrolment (12-question Flutter form)
  capturedAt        DateTime @default(now())
  capturedBy        String?
  captureMethod     String   @default("FLUTTER_FORM")  // FLUTTER_FORM | USSD | FIELD_OFFICER | IMPORTED

  // Income baseline (USD per year)
  baselineIncomeUsd      Float?
  baselineIncomeSources  String?  // JSON array: ["coffee", "maize", "vsla"]

  // Yield baseline (kg/ha for primary crop)
  baselineYieldKgHa      Float?
  baselineCrop           String?

  // Practice baseline (JSON array of practices already adopted)
  baselinePractices      String   @default("[]")  // JSON: ["shade_trees","no_till"]
  practiceCountBaseline  Int      @default(0)

  // Plot + household baseline
  plotCountBaseline      Int      @default(0)
  totalAreaHectares      Float?
  householdSize          Int?
  womenInLeadership      Boolean  @default(false)

  // Financial baseline
  hasBankAccount         Boolean  @default(false)
  hasMobileMoney         Boolean  @default(false)
  savingsBalanceUsd      Float?
  outstandingLoanUsd     Float?

  // Climate baseline
  climateRiskExposure    String?  // LOW | MEDIUM | HIGH | CRITICAL
  deforestationRisk      Boolean  @default(false)

  notes                  String?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([tenantId])
  @@index([capturedAt])
}

model ImpactEvent {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation("TenantImpactEvents", fields: [tenantId], references: [id])
  farmerId          String
  farmer            FarmerProfile @relation("FarmerImpactEvents", fields: [farmerId], references: [id], onDelete: Cascade)

  // Event type: HARVEST, PRACTICE_ADOPTED, TRAINING_COMPLETED, PAYMENT_RECEIVED,
  // PLOT_VERIFIED, CERTIFICATION_ISSUED, LOAN_DISBURSED, LOAN_REPAID, ETC.
  eventType         String
  eventData         String   // JSON: event-specific payload

  // SHA-256 hash chain — each event hash = SHA256(prevHash + eventData + timestamp)
  // This makes the ledger tamper-evident. Anyone can verify the chain with a script.
  prevHash          String?
  hash              String   @unique

  // Optional links to other records
  relatedId         String?
  relatedType       String?  // PLOT | TRAINING | PAYMENT | CERTIFICATION | LOAN | PRACTICE

  // Actor (who triggered the event)
  actorId           String?
  actorName         String?
  actorType         String?  // FARMER | EXTENSION_OFFICER | SYSTEM | COOPERATIVE_MANAGER

  // Location (optional, for geo-tagged events)
  latitude          Float?
  longitude         Float?

  timestamp         DateTime @default(now())
  createdAt         DateTime @default(now())

  @@index([tenantId])
  @@index([farmerId])
  @@index([eventType])
  @@index([timestamp])
}

model ImpactKpiSnapshot {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation("TenantImpactKpiSnapshots", fields: [tenantId], references: [id])
  farmerId          String
  farmer            FarmerProfile @relation("FarmerImpactKpiSnapshots", fields: [farmerId], references: [id], onDelete: Cascade)

  // KPI code (I-01 through CP-05 — see strategy brief)
  kpiCode           String   // e.g. "I-01", "Y-02", "C-04"
  pillar            String   // INCOME | YIELD | CLIMATE | INCLUSION | COMPLIANCE

  // Computed value
  value             Float
  unit              String   // USD | kg/ha | % | score | tCO2e | days
  period            String   // e.g. "2026-06" (monthly) or "2026A" (season)

  // Attribution
  attributionMethod String   @default("NAIVE")  // NAIVE | DID_MATCHED | SYNTHETIC_CONTROL
  controlGroupId    String?  // for DiD: the matched control farmer's ID
  confidenceScore   Float?   // 0-1 confidence in the attribution

  // Baseline + target for quick % calc
  baselineValue     Float?
  targetValue       Float?

  computedAt        DateTime @default(now())

  @@unique([farmerId, kpiCode, period])
  @@index([tenantId])
  @@index([farmerId])
  @@index([kpiCode])
  @@index([period])
  @@index([pillar])
}

model PracticeAdoption {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation("TenantPracticeAdoptions", fields: [tenantId], references: [id])
  farmerId          String
  farmer            FarmerProfile @relation("FarmerPracticeAdoptions", fields: [farmerId], references: [id], onDelete: Cascade)

  // Farm5x practice code — e.g. "1M5C_MUST" (shade trees), "1M5C_R1" (organic mulch)
  practiceCode      String
  cropType          String   // COFFEE | MAIZE | COCOA | TEA | DAIRY
  frameworkVariant  String   // 1M5C | 1M5M | 1M5K | 1M5T | 1M5D
  isMandatory       Boolean  @default(false)  // true if this is the "Must" practice

  // Adoption details
  adoptedAt         DateTime @default(now())
  adoptedBy         String?  // FARMER | EXTENSION_OFFICER
  plotId            String?  // optional: which plot

  // Verification — satellite or field officer confirmation
  verificationStatus String  @default("PENDING")  // PENDING | VERIFIED | REJECTED
  verificationMethod String?  // SATELLITE | FIELD_OFFICER | PHOTO | IoT
  verifiedAt        DateTime?
  verifiedBy        String?
  confidenceScore   Float?   // 0-1
  evidenceUrl       String?  // photo or satellite image URL

  notes             String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
  @@index([farmerId])
  @@index([practiceCode])
  @@index([cropType])
  @@index([verificationStatus])
  @@index([adoptedAt])
}

model ClimateResilienceScore {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation("TenantClimateResilienceScores", fields: [tenantId], references: [id])
  farmerId          String
  farmer            FarmerProfile @relation("FarmerClimateResilienceScores", fields: [farmerId], references: [id], onDelete: Cascade)

  // Score period (monthly computation)
  period            String   @default("2026-06")  // YYYY-MM
  computedAt        DateTime @default(now())

  // Total score (0-100)
  score             Int

  // 4-factor breakdown
  practicePoints    Int      @default(0)   // /40 — Farm5x practice adoption
  yieldPoints       Int      @default(0)   // /20 — yield stability over 3 seasons
  trainingPoints    Int      @default(0)   // /20 — training completion
  climatePoints     Int      @default(0)   // /20 — climate exposure (lower risk = more points)

  // Risk category derived from score
  riskCategory      String   // LOW_RISK | MEDIUM_RISK | HIGH_RISK | CRITICAL_RISK

  // Inputs that produced this score (for auditability)
  inputs            String   // JSON: { practiceCount, yieldCV, trainingCount, climateExposure }

  // Trend vs previous period
  previousScore     Int?
  trend             String?  // IMPROVING | STABLE | DECLINING

  @@unique([farmerId, period])
  @@index([tenantId])
  @@index([farmerId])
  @@index([period])
  @@index([riskCategory])
  @@index([score])
}
