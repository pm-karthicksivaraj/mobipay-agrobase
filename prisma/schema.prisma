  commodity                 String
  originCountry             String
  quantityTonnes            Float
  embeddedEmissionsPerTonne Float
  totalEmbeddedEmissions    Float
  euCarbonPrice             Float
  cbamCertificateCost       Float
  carbonCreditsApplied      Float    @default(0)
  netCost                   Float
  reportingPeriod           String
  status                    String   @default("DRAFT")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

// --- TRACEABILITY ---

model ProductBatch {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  batchId           String   @unique
  farmerId          String?
  farmer            FarmerProfile? @relation("FarmerBatches", fields: [farmerId], references: [id])
  cooperativeId     String?
  commodity         String
  variety           String?
  quantityKg        Float
  farmLandId        String?
  farmName          String?
  season            String?
  sowingDate        DateTime?
  harvestDate       DateTime?
  status            String   @default("GROWING")
  currentStage      String   @default("FARM")
  qualityGrade      String?
  eudrComplianceId  String?
  carbonFootprintId String?
  traceEventCount   Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  events            TraceEvent[]
}

model TraceEvent {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  productBatchId    String
  productBatch      ProductBatch @relation(fields: [productBatchId], references: [id], onDelete: Cascade)
  eventType         String
  stage             String
  timestamp         DateTime @default(now())
  locationName      String?
  latitude          Float?
  longitude         Float?
  actorId           String?
  actorName         String?
  actorType         String?
  details           String?  // JSON
  evidence          String?  // JSON array of {type, url, description}
  verificationHash  String?
  createdAt         DateTime @default(now())
}

// --- FARM PASSPORT ---

model FarmPassport {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  passportId        String   @unique  // AGRO-UG-2026-ABCDEF
  farmerId          String   @unique
  farmer            FarmerProfile @relation("FarmerPassport", fields: [farmerId], references: [id])
  passportData      String   // JSON - full passport snapshot
  generatedAt       DateTime @default(now())
  regeneratedAt     DateTime?
  qrCodeUrl         String?
  verificationUrl   String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// --- COST OF CULTIVATION ---

model CostOfCultivation {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  farmerId        String?
  farmId          String?
  commodity       String
  country         String
  areaHectares    Float
  season          String?
  costBreakdown   String   // JSON: {landPrep, seeds, fertilizer, pesticide, labor, ...}
  totalCost       Float
  expectedYield   Float
  expectedRevenue Float
  actualYield     Float?
  actualRevenue   Float?
  profitLoss      Float?
  roi             Float?
  status          String   @default("ESTIMATED") // ESTIMATED, ACTUAL
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// --- EUDR ENHANCEMENTS ---

model EudrDocument {
  id                String   @id @default(cuid())
  eudrComplianceId  String
  eudrCompliance    EudrCompliance @relation("EudrDocuments", fields: [eudrComplianceId], references: [id], onDelete: Cascade)
  documentType      String  // LAND_TITLE, USE_RIGHTS, ENVIRONMENTAL_PERMIT, SURVEY_MAP
  fileName          String
  fileUrl           String?
  fileSize          Int?
  uploadedAt        DateTime @default(now())
  verified          Boolean  @default(false)
  verifiedBy        String?
  verifiedAt        DateTime?
}

model EudrAuditLog {
  id                String   @id @default(cuid())
  eudrComplianceId  String
  eudrCompliance    EudrCompliance @relation("EudrAuditLogs", fields: [eudrComplianceId], references: [id], onDelete: Cascade)
  action            String  // CREATED, SUBMITTED, VERIFIED, REJECTED, EXPIRED, RENEWED
  performedBy       String?
  performedAt       DateTime @default(now())
  details           String?
}

// ============================================
// PHASE 4 — ECOSYSTEM LAYER
// ============================================

// --- NOTIFICATION ENGINE ---

model NotificationTemplate {
  id          String   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?  @relation("TenantNotifications", fields: [tenantId], references: [id])
  name        String
  code        String   @unique
  channel     String
  subject     String?
  body        String
  variables   String   @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  notifications Notification[]
}

model Notification {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation("TenantNotifRecords", fields: [tenantId], references: [id])
  templateId      String?
  template        NotificationTemplate? @relation(fields: [templateId], references: [id])
  userId          String?
  user            User?    @relation("UserNotifications", fields: [userId], references: [id])
  recipientPhone  String?
  recipientEmail  String?
  channel         String
  category        String
  subject         String?
  body            String
  data            String?
  status          String   @default("PENDING")
  providerMessageId String?
  error           String?
  scheduledAt     DateTime?
  sentAt          DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deliveries NotificationDelivery[]
}

model NotificationDelivery {
  id              String   @id @default(cuid())
  notificationId  String
  notification    Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  channel         String
  provider        String
  attempt         Int      @default(1)
  status          String   @default("PENDING")
  responseCode    String?
  responseMessage String?
  sentAt          DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime @default(now())
}

// --- WEBHOOK SYSTEM ---

model WebhookEndpoint {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation("TenantWebhooks", fields: [tenantId], references: [id])
  name        String
  url         String
  secret      String
  events      String
  isActive    Boolean  @default(true)
  lastPingAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deliveries WebhookDelivery[]
}

model WebhookDelivery {
  id            String   @id @default(cuid())
  endpointId    String
  endpoint      WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  event         String
  payload       String
  signature     String?
  status        String   @default("PENDING")
  statusCode    Int?
  responseBody  String?
  attempt       Int      @default(1)
  maxAttempts   Int      @default(3)
  nextRetryAt   DateTime?
  sentAt        DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// --- INVENTORY / WAREHOUSE ---

model Warehouse {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation("TenantWarehouses", fields: [tenantId], references: [id])
  name        String
  code        String   @unique
  address     String?
  country     String
  region      String?
  district    String?
  capacity    Float?
  managerId   String?  @unique
  manager     User?    @relation("WarehouseManager", fields: [managerId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  stockItems  StockItem[]
  movements   StockMovement[]
  inspections QualityInspection[] @relation("WarehouseInspections")
}

model StockItem {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation("TenantStockItems", fields: [tenantId], references: [id])
  warehouseId   String
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
  commodity     String
  variety       String?
  grade         String?
  batchCode     String?
  quantity      Float    @default(0)
  unit          String   @default("KG")
  unitPrice     Float?
  minLevel      Float    @default(0)
  maxLevel      Float?
  location      String?
  expiryDate    DateTime?
  status        String   @default("AVAILABLE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  movements StockMovement[]
  inspections QualityInspection[]
}

model StockMovement {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation("TenantStockMovements", fields: [tenantId], references: [id])
  warehouseId   String
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
  stockItemId   String
  stockItem     StockItem @relation(fields: [stockItemId], references: [id])
  type          String
  quantity      Float
  unitPrice     Float?
  referenceId   String?
  referenceType String?
  fromWarehouseId String?
  toWarehouseId   String?
  notes         String?
  performedBy   String?
  createdAt     DateTime @default(now())
}

// --- QUALITY MANAGEMENT ---

model GradeDefinition {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation("TenantGradeDefs", fields: [tenantId], references: [id])
  commodity   String
  grade       String
  description String?
  criteria    String
  pricePremium Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  inspections QualityInspection[]
}

model QualityInspection {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation("TenantQualityInspections", fields: [tenantId], references: [id])
  warehouseId   String?
  warehouse     Warehouse? @relation("WarehouseInspections", fields: [warehouseId], references: [id])
  stockItemId   String?
  stockItem     StockItem? @relation(fields: [stockItemId], references: [id])
  gradeDefId    String?
  gradeDef      GradeDefinition? @relation(fields: [gradeDefId], references: [id])
  batchCode     String?
  commodity     String
  sampleWeight  Float
  parameters    String
  overallScore  Float?
  grade         String?
  passed        Boolean?
  inspectorId   String?
  inspector     User?    @relation("QualityInspector", fields: [inspectorId], references: [id])
  notes         String?
  status        String   @default("DRAFT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// --- CONTRACT MANAGEMENT ---

model Contract {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation("TenantContracts", fields: [tenantId], references: [id])
  contractCode  String   @unique
  type          String
  status        String   @default("DRAFT")
  buyerId       String?
  buyerName     String?
  sellerId      String?
  sellerName    String?
  commodity     String
  variety       String?
  grade         String?
  quantity      Float
  unitPrice     Float
  currency      String   @default("UGX")
  totalValue    Float
  startDate     DateTime
  endDate       DateTime
  deliveryTerms String?
  paymentTerms  String?
  qualitySpecs  String?
  penalties     String?
  notes         String?
  signedAt      DateTime?
  signedBy      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  items      ContractItem[]
  milestones ContractMilestone[]
  shipments  Shipment[]
}

model ContractItem {
  id          String   @id @default(cuid())
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  commodity   String
  variety     String?
  grade       String?
  quantity    Float
  unitPrice   Float
  delivered   Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContractMilestone {
  id          String   @id @default(cuid())
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  name        String
  dueDate     DateTime
  quantity    Float?
  amount      Float?
  status      String   @default("PENDING")
  completedAt DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- LOGISTICS ---

model Vehicle {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation("TenantVehicles", fields: [tenantId], references: [id])
  plateNumber String   @unique
  type        String
  capacity    Float
  driverName  String?
  driverPhone String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  shipments   Shipment[]
}

model Shipment {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation("TenantShipments", fields: [tenantId], references: [id])
  shipmentCode  String   @unique
  vehicleId     String?
  vehicle       Vehicle? @relation(fields: [vehicleId], references: [id])
  contractId    String?
  contract      Contract? @relation(fields: [contractId], references: [id])
  originId      String?
  destinationId String?
  status        String   @default("PLANNED")
  departureTime DateTime?
  arrivalTime   DateTime?
  driverName    String?
  driverPhone   String?
  totalWeight   Float?
  route         String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  items ShipmentItem[]
}

model ShipmentItem {
  id          String   @id @default(cuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  commodity   String
  grade       String?
  quantity    Float
  batchCode   String?
  createdAt   DateTime @default(now())
}

// --- PARTNER MANAGEMENT ---

model Partner {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation("TenantPartners", fields: [tenantId], references: [id])
  name          String
  type          String
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  address       String?
  country       String?
  commissionRate Float?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  commissions    CommissionRule[]
  settlements    CommissionSettlement[]
}

model CommissionRule {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation("TenantCommissionRules", fields: [tenantId], references: [id])
  partnerId     String
  partner       Partner @relation(fields: [partnerId], references: [id])
  name          String
  type          String
  basis         String
  rate          Float
  minAmount     Float?
  maxAmount     Float?
  conditions    String?
  isActive      Boolean  @default(true)
  effectiveFrom DateTime @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  settlements   CommissionSettlement[]
}

model CommissionSettlement {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation("TenantCommissionSettlements", fields: [tenantId], references: [id])
  partnerId     String
  partner       Partner @relation(fields: [partnerId], references: [id])
  ruleId        String?
  rule          CommissionRule? @relation(fields: [ruleId], references: [id])
  period        String
  referenceId   String?
  amount        Float
  currency      String   @default("UGX")
  status        String   @default("PENDING")
  paidAt        DateTime?
  paidVia       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// --- BULK OPERATIONS ---

model BulkOperation {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation("TenantBulkOps", fields: [tenantId], references: [id])
  type          String
  status        String   @default("PENDING")
  fileName      String
  fileSize      Int?
  totalRows     Int      @default(0)
  processedRows Int      @default(0)
  successRows   Int      @default(0)
  failedRows    Int      @default(0)
  errorSummary  String?
  configFile   String?
  resultFileUrl String?
  performedBy   String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// --- ANALYTICS & DASHBOARDS ---

model DashboardWidget {
  id          String   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?  @relation("TenantDashWidgets", fields: [tenantId], references: [id])
  name        String
  type        String
  dataSource  String
  config      String
  position    Int      @default(0)
  size        String   @default("MEDIUM")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ReportTemplate {
  id          String   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?  @relation("TenantReportTemplates", fields: [tenantId], references: [id])
  name        String
  code        String   @unique
  description String?
  type        String
  format      String   @default("PDF")
  sections    String
  parameters  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  schedules ScheduledReport[]
}

model ScheduledReport {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation("TenantScheduledReports", fields: [tenantId], references: [id])
  templateId    String
  template      ReportTemplate @relation(fields: [templateId], references: [id])
  name          String
  schedule      String
  cronExpression String?
  recipients    String
  parameters    String?
  lastRunAt     DateTime?
  nextRunAt     DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================
// PHASE 4B — DEVELOPER PLATFORM & ECOSYSTEM
// ============================================

// --- i18n / TRANSLATIONS ---

model Translation {
  id          String   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?  @relation("TenantTranslations", fields: [tenantId], references: [id])
  locale      String                       // en, sw, lg, ach, luo, fr, etc.
  namespace   String   @default("common")  // common, farmers, marketplace, reports, etc.
  key         String                       // e.g. "welcome.title", "error.not_found"
  value       String                       // Translated text
  isSystem    Boolean  @default(false)     // System-level translations (not editable by tenant)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, locale, namespace, key])
}

// --- WHITE-LABEL / BRANDING ---

model BrandingConfig {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  tenant        Tenant   @relation("TenantBranding", fields: [tenantId], references: [id])
  primaryColor  String   @default("#16a34a")
  secondaryColor String  @default("#facc15")
  accentColor   String   @default("#0ea5e9")
  logoUrl       String?
  faviconUrl    String?
  appName       String?                      // Override "Agrobase V3"
  tagline       String?
  locale        String   @default("en")     // Default locale for this tenant
  dateFormat    String   @default("DD/MM/YYYY")
  currencyFormat String  @default("symbol") // symbol, code, none
  timezone      String   @default("Africa/Kampala")
  customCSS     String?                      // Custom CSS overrides
  loginImageUrl String?                      // Custom login page background
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// --- MULTI-CURRENCY / EXCHANGE RATES ---

model ExchangeRate {
  id            String   @id @default(cuid())
  fromCurrency  String
  toCurrency    String
  rate          Float
  source        String   @default("manual")
  validFrom     DateTime @default(now())
  createdAt     DateTime @default(now())

  @@unique([fromCurrency, toCurrency])
}