  partnerType         String   // BANK | MFI | SACCO
  code                String?
  contactName         String?
  contactEmail        String?
  contactPhone        String?
  address             String?
  country             String?
  apiEndpoint         String?
  apiKey              String?
  maxExposure         Decimal? @db.Decimal(18, 2)
  currentExposure     Decimal  @default(0) @db.Decimal(18, 2)
