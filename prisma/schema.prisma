  tenantId             String
  tenant               Tenant   @relation("TenantMfiLoanProducts", fields: [tenantId], references: [id])
  partnerId            String?
  partner              MfiPartner? @relation(fields: [partnerId], references: [id])
  name                 String
  description          String?
  interestRateType     String   @default("FLAT") // FLAT | DECLINING_BALANCE | AMORTIZED
  interestRate         Decimal  @db.Decimal(8, 4)
  maxAmount            Decimal  @db.Decimal(18, 2)
  minAmount            Decimal? @db.Decimal(18, 2)
  maxDurationMonths    Int
  gracePeriodMonths    Int      @default(0)
  latePaymentPenalty   Decimal? @db.Decimal(8, 4)
  processingFeePercent Decimal? @db.Decimal(8, 4)
  insuranceFeePercent  Decimal? @db.Decimal(8, 4)
  collateralRequired   Boolean  @default(false)
  requiredDocuments    String?  // JSON
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

